<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <awsAccessKey xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsAccessSecret xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsRegion xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsRole xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsStsArnRole xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsStsExternalId xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <awsStsRoleSessionDuration xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <certificate xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <clientCertificate xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <clientCertificatePassphrase xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <description>Loadsmart API OAuth 2.0 credentials for shipment polling and updates</description>
    <endpoint>https://api.loadsmart.com/auth/token</endpoint>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <jwtAudience xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <jwtFormulaSubject xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <jwtIssuer xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <jwtSigningCertificate xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <jwtTextFormula xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <jwtValidityPeriodSeconds xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <label>Loadsmart API</label>
    <oauthRefreshTokenUrl>https://api.loadsmart.com/auth/token</oauthRefreshTokenUrl>
    <oauthScopeRequired>false</oauthScopeRequired>
    <oauthToken xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <password>YOUR_LOADSMART_CLIENT_SECRET</password>
    <principalType>NamedUser</principalType>
    <privateKeyFile xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
    <protocol>Password</protocol>
    <timeout>10000</timeout>
    <username>YOUR_LOADSMART_CLIENT_ID</username>
</NamedCredential>
