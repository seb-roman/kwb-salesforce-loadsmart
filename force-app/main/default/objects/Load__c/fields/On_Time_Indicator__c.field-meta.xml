<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>On_Time_Indicator__c</fullName>
    <description>Indicates whether the delivery was on time. Compares actual delivery to estimated delivery.</description>
    <externalId>false</externalId>
    <formula>IF(
    ISBLANK(Delivery_Window_Actual_Begin__c),
    "Pending",
    IF(Delivery_Window_Actual_Begin__c &lt;= Estimated_Delivery_DateTime__c, "On Time", "Late")
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>On Time Indicator</label>
    <required>false</required>
    <type>Text</type>
</CustomField>