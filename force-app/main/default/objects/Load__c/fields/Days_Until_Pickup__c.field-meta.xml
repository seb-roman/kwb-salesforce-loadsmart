<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Days_Until_Pickup__c</fullName>
    <description>Number of days from today until scheduled pickup</description>
    <externalId>false</externalId>
    <formula>FLOOR(Pickup_Window_Begin__c - NOW())</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Days Until Pickup</label>
    <precision>5</precision>
    <required>false</required>
    <scale>0</scale>
    <type>Number</type>
</CustomField>
