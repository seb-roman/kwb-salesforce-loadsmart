<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Transit_Hours__c</fullName>
    <description>Estimated transit hours from pickup to delivery window</description>
    <externalId>false</externalId>
    <formula>(Delivery_Window_Begin__c - Pickup_Window_Begin__c) * 24</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Transit Hours</label>
    <precision>8</precision>
    <required>false</required>
    <scale>2</scale>
    <type>Number</type>
</CustomField>
