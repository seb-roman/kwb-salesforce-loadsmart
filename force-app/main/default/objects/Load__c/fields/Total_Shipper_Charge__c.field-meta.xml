<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Total_Shipper_Charge__c</fullName>
    <description>Total amount charged to shipper (base rate + fuel surcharge + accessorials)</description>
    <externalId>false</externalId>
    <formula>Billing_Rate__c + IF(ISNULL(Fuel_Surcharge__c), 0, Fuel_Surcharge__c) + IF(ISNULL(Accessorials__c), 0, Accessorials__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Total Shipper Charge</label>
    <precision>12</precision>
    <required>false</required>
    <scale>2</scale>
    <type>Currency</type>
</CustomField>
