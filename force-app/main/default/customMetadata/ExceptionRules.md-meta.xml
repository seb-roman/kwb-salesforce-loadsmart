<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <label>Exception Rules</label>
    <pluralLabel>Exception Rules</pluralLabel>
    <fields>
        <fullName>Rule_Name__c</fullName>
        <description>Name of the exception rule</description>
        <label>Rule Name</label>
        <length>100</length>
        <required>false</required>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Threshold__c</fullName>
        <description>Numeric threshold value that triggers the exception (e.g., hours late, delivery days)</description>
        <label>Threshold</label>
        <precision>8</precision>
        <required>false</required>
        <scale>2</scale>
        <type>Number</type>
    </fields>
    <fields>
        <fullName>Severity__c</fullName>
        <description>Severity level of the exception (Critical, High, Medium, Low)</description>
        <label>Severity</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Critical</fullName>
                    <default>false</default>
                    <label>Critical</label>
                </value>
                <value>
                    <fullName>High</fullName>
                    <default>false</default>
                    <label>High</label>
                </value>
                <value>
                    <fullName>Medium</fullName>
                    <default>false</default>
                    <label>Medium</label>
                </value>
                <value>
                    <fullName>Low</fullName>
                    <default>false</default>
                    <label>Low</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Enabled__c</fullName>
        <description>Whether this exception rule is currently enabled</description>
        <label>Enabled</label>
        <required>false</required>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <description>Description of when this exception rule applies</description>
        <label>Description</label>
        <length>500</length>
        <required>false</required>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <visibility>Public</visibility>
</CustomMetadata>